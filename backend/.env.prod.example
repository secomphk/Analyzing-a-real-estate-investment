# ╔════════════════════════════════════════════════════════════════════════════
# ║ Production / staging template
# ║
# ║ Used by Railway (or any host) for backend-prod / backend-staging.
# ║ Never commit `.env.prod` — it lives in the host's secret manager.
# ║
# ║ Most fields are auto-injected by Railway's add-ons (Postgres / Redis):
# ║ for those, only POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB / REDIS_URL
# ║ need to come from the add-on. Compose interpolates the rest.
# ╚════════════════════════════════════════════════════════════════════════════

# ─── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=production       # or `staging`
LOG_LEVEL=INFO
DEBUG=false

# ─── Server ─────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
# Comma-separated; include the Vercel frontend URL + any custom domain.
CORS_ORIGINS=https://realestate-analyzer.vercel.app,https://app.example.com

# ─── Database (Railway Postgres add-on injects these) ───────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=realestate
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@postgres:5432/realestate
DATABASE_URL_SYNC=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/realestate

# ─── Redis (Railway Redis add-on) ───────────────────────────────────────────
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
FEATURE_CACHE_TTL_SECONDS=86400

# ─── External APIs (copy from .env.local once verified) ─────────────────────
KAKAO_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
REALTY_PRICE_API_KEY=
MOLIT_API_KEY=
ADMIN_POPULATION_API_KEY=

# ─── ML / MLflow ────────────────────────────────────────────────────────────
# Self-hosted or Databricks Free.
MLFLOW_TRACKING_URI=
MODELS_DIR=/app/models_artifacts
# Optional: sync model artifacts from S3 at boot.
MODELS_S3_URI=

# ─── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Auth (Phase 2 placeholder) ─────────────────────────────────────────────
# Generate per-environment:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute

# ─── Operator switches ──────────────────────────────────────────────────────
ETL_KILL_SWITCH=

# ─── Container / Boot ───────────────────────────────────────────────────────
# Run alembic at container startup so deploys auto-migrate.
MIGRATE_ON_BOOT=true
# Number of uvicorn workers.
UVICORN_WORKERS=4
