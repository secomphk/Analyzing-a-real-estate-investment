# ╔════════════════════════════════════════════════════════════════════════════
# ║ Backend environment template  (committed — never put real secrets here)
# ║
# ║ Copy to `.env` and fill in the empty values:
# ║
# ║     cp .env.example .env
# ║
# ║ The real `.env` is git-ignored. Production reads these same variables
# ║ from Railway / a secret manager — keep the keys identical.
# ╚════════════════════════════════════════════════════════════════════════════

# ─── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# ─── Server ─────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ───────────────────────────────────────────────────────────────
# Without Docker:
DATABASE_URL=postgresql+asyncpg://realestate:realestate@localhost:5432/realestate
DATABASE_URL_SYNC=postgresql://realestate:realestate@localhost:5432/realestate
# docker-compose overrides these to use the in-network `postgres` host.

POSTGRES_USER=realestate
POSTGRES_PASSWORD=realestate
POSTGRES_DB=realestate

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
FEATURE_CACHE_TTL_SECONDS=86400

# ─── External APIs ──────────────────────────────────────────────────────────
# Kakao Developers REST API key (OPTIONAL).
# Local API now requires Business App registration; we use Naver/V-World
# instead. The frontend Maps JS SDK (VITE_KAKAO_MAP_KEY) does NOT need a
# Business App.
KAKAO_API_KEY=

# Step 1' — Naver Open API (recommended geocoder, no business cert needed)
#   https://developers.naver.com → Application → 검색 → 지역 사용
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Step 2 — V-World 공시지가 + 건축물대장 + 보조 geocoder
#   https://www.vworld.kr → 인증키 발급 → "Open API" 인증키
REALTY_PRICE_API_KEY=

# Step 3 — 국토교통부 실거래가 (data.go.kr — 1일 검토)
#   https://www.data.go.kr → 부동산 실거래가 → 활용신청
MOLIT_API_KEY=

# Step 3 — 행정안전부 주민등록 인구 (data.go.kr)
ADMIN_POPULATION_API_KEY=

# ─── ML / MLflow ────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=file:./mlruns
MODELS_DIR=./models_artifacts

# ─── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Auth (Phase 2 placeholder) ─────────────────────────────────────────────
# Generate a fresh value when copying to `.env`:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute

# ─── Operator switches ──────────────────────────────────────────────────────
# Set ETL_KILL_SWITCH=1 to immediately abort every running ETL.
ETL_KILL_SWITCH=