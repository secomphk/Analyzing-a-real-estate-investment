# Backend base URL. Leave blank to use the Vite proxy (recommended in dev).
VITE_API_URL=

# Kakao JavaScript SDK app key. Required by the map components.
# Get one at https://developers.kakao.com/console/app
VITE_KAKAO_MAP_KEY=

# Optional: where the dev proxy forwards /api/* to.
VITE_PROXY_TARGET=http://localhost:8000
